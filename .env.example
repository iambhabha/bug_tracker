# Environment Variables for Bug Tracker

## Telegram Configuration
TELEGRAM_TOKEN=your_telegram_bot_token_here
SHEET_WEBHOOK=your_google_sheets_webhook_url_here

## Trello Configuration
TRELLO_KEY=your_trello_api_key
TRELLO_TOKEN=your_trello_api_token
TRELLO_BOARD_ID=69bcc0a478f5faa9a902ee43

## Server Configuration
PORT=3000

# Note: The list ID mapping is now hardcoded in server.js based on your board:
# - Issues List (Todo): 69bcd685eab03493fbad667e → OPEN
# - In Development List: 69bcd6995ed92343b8dfee81 → IN PROGRESS  
# - Review List: 69bcc0a478f5faa9a902ee40 → IN REVIEW
# - Done List: 69bcc0a478f5faa9a902ee42 → DONE
